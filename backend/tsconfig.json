{
  "compilerOptions": {
    "target": "ES2020",                  // Compatible with modern Node versions
    "module": "CommonJS",                // Simplifies import/export with most packages
    "moduleResolution": "node",          // Node-style module resolution
    "esModuleInterop": true,             // Smooth interop for CommonJS modules
    "strict": true,                      // Strict type checking
    "skipLibCheck": true,                // Skip type checks for libraries (speeds up build)
    "forceConsistentCasingInFileNames": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./",
    "types": ["node"],
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules"]
}